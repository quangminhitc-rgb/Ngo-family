# ===========================
# NEXTAUTH CONFIGURATION
# ===========================
# Tạo secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="https://your-app.vercel.app"

# ===========================
# DATABASE (Supabase PostgreSQL)
# ===========================
# Lấy từ Supabase > Project Settings > Database > Connection string
# URI = dùng connection pooler (port 6543) — dùng cho app
DATABASE_URL="postgresql://postgres.xxx:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct = không qua pooler (port 5432) — dùng cho migrations
DIRECT_URL="postgresql://postgres.xxx:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ===========================
# SUPABASE STORAGE
# ===========================
# Lấy từ Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ===========================
# UPLOAD SETTINGS
# ===========================
MAX_FILE_SIZE=10485760

# ===========================
# APP SETTINGS
# ===========================
NEXT_PUBLIC_APP_NAME="Gia Đình Tôi"
NEXT_PUBLIC_APP_DESCRIPTION="Không gian riêng của gia đình"
